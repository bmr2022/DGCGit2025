@using eTactWeb.Data.Common
@model eTactWeb.DOM.Models.UnitMasterModel;
@inject EncryptDecrypt encryptDecrypt
<div class="table-responsive" style="max-height:350px;">
    <table class="table table-hover table-bordered table-striped TbCss text-nowrap mb-0" id="GateDataTable" style="width: 100%;">
        <thead class="bg-gradient card-headerBG text-light" style="position:static;" id="dashGateThead">
            <tr>
                <th>Sr#</th>
                <th style="width:50px !important">Action</th>
                <th>Unit Name</th>
                <th>Branch</th>
                <th>Unit Detail</th>
                <th>Round Off</th>
            </tr>
        </thead>
        <tbody id="gateDashboardtable">
            @{
                var Cntr = 0;
                if (Model.UnitMasterDashBoardGrid == null || Model.UnitMasterDashBoardGrid.Count == 0)
                {
                    <tr class="text-center"><td colspan="11" class="text-black-50"><strong>NO DATA FOUND</strong></td></tr>
                }
                else
                {
                    foreach (var item in Model.UnitMasterDashBoardGrid)
                    {
                        Cntr = Cntr + 1;
                        <tr onclick="selection(this)">
                            <td>@Cntr</td>
                            <td style="text-align:center;white-space: nowrap;">
                                <div id="container">

                                    <div id="viewCursorDiv-@Cntr">
                                        <a class="table-link link-success" asp-action="UnitMaster" asp-route-Mode="@encryptDecrypt.Encrypt("V")" asp-route-Unit_Name="@encryptDecrypt.Encrypt(item.Unit_Name ?? "")">
                                            <span class="fa-stack">
                                                <i class="fa fa-square fa-stack-2x"></i>
                                                <i class="fa-solid fa-magnifying-glass fa-stack-1x fa-inverse"></i>
                                            </span>
                                        </a>
                                    </div>

                                    <div id="editCursorDiv-@Cntr">
                                        @* <a class="table-link link-primary" id="editCursor-@Cntr" asp-action="LedgerOpeningEntry" onclick="confirmEdit(event)" asp-controller="LedgerOpeningEntry" asp-route-Mode="U" asp-route-ID="@item.EntryByEmpId" asp-route-YC="@item.ClosingYearCode" asp-route-EntryByMachine="@item.EntryByMachine" asp-route-AccountCode="@item.AccountCode">*@
                                        <a class="table-link link-primary"
                                               asp-action="UnitMaster"
                                               asp-controller="UnitMaster"
                                               asp-route-Mode="@encryptDecrypt.Encrypt("U")"
                                               asp-route-Unit_Name="@encryptDecrypt.Encrypt(item.Unit_Name ?? "")"
                                               onclick="confirmEdit(event)">

                                            <span class="fa-stack">
                                                <i class="fa fa-square fa-stack-2x"></i>
                                                <i class="fa fa-pencil fa-stack-1x fa-inverse"></i>
                                            </span>
                                        </a>

                                    </div>
                                    <div id="deleteCursorDiv-@Cntr">
                                        <a class="table-link link-danger" id="deleteCursor-@Cntr" onclick="confirmDelete(event)" asp-action="DeleteByID" asp-route-Unit_Name="@item.Unit_Name">
                                            <span class="fa-stack">
                                                <i class="fa fa-square fa-stack-2x"></i>
                                                <i class="fa-solid fa-trash fa-stack-1x fa-inverse"></i>
                                            </span>
                                        </a>
                                    </div>
                                </div>
                            </td>

                            <td>@item.Unit_Name</td>
                            <td>@item.CC</td>
                            <td>@item.UnitDetail</td>
                            <td>@item.Round_Off</td>
                            
                          

                        </tr>
                    }
                }
            }
        </tbody>
    </table>
</div>
<center><strong>TOTAL ROWS : <span id="totalRows">@Cntr</span></strong></center>



<style>
    /* #container {
            display: flex;
        }

            #container > div {
                flex: 1;
                margin-right: 10px;
            } */
    #container {
        display: flex;
        justify-content: center; /* center the icons */
        gap: 5px; /* space between icons */
    }

        #container > div {
            flex: 0 0 auto; /* shrink to fit content */
            margin-right: 0; /* remove extra margin */
        }


    #GateDataTable {
        width: 100%;
        border-collapse: collapse;
    }

    #dashGateThead th {
        background-color: #127387;
        position: sticky;
        top: -2px;
        z-index: 1;
    }

    .sort-icon {
        padding: 5px;
        margin: 5px;
        vertical-align: top;
    }

    .ascCol {
        font-size: 15px;
        vertical-align: bottom;
    }

    .descCol {
        font-size: 15px;
        vertical-align: super;
    }

    table {
        width: 100%; /* Ensure table fills the container width */
    }

    th, td {
        white-space: nowrap; /* Prevent content from wrapping */
    }
</style>
