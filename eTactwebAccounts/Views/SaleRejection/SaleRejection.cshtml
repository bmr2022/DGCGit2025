        function DueDateCalculation() {

            // var dueDate = $('#AdjDueDate').val();
            // var dateStr = parseDateToFormat($('#CustInvoiceDate').val().split(" ")[0]);
            // var [day, month, year] = dateStr.split('/').map(Number);
