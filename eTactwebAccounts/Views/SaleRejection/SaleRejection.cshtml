                    if ($('#divTaxGrid tr td').length <= 1 && $('#DomesticExportNEPZ').val() === "DOMESTIC") {
                        $.notify('Tax Grid Should Have Atleast 1 Item...!', "error");
                        return;
                    }


                }
                else if ($('#divAdjItemList tr td').length <= 1) {
                    $.notify('Adjust Grid Should Have Atleast 1 Item...!', "error");
                    return;
                }



                // Check for CR in Adjustment Grid
                else if (drCrGrid <= 1) {
                    $.notify("Debit And Credit Amount Status Grid should at least have one item", "error");
                    return;
                }
                else if (drCrGrid >= 1 && $('#TotalDr').text() != $('#TotalCr').text()) {
                    $.notify("Total Debit And Total Credit Amount should be same", "error");
                    return;
                }
                // $("form").submit();


                // 🔥 AJAX SUBMIT
                $.ajax({
                    url: $('form').attr('action'),
                    type: $('form').attr('method'),
                    data: $('form').serialize(),
                    beforeSend: function () {
                        $('#ajaxLoader').show(); // ✅ Show loader
                    },
                    success: function (response) {

                        // Success from controller
                        if (response.success) {

                            if (response.redirectUrl) {

                                window.location.href = response.redirectUrl;

                            }


                            $('#ajaxLoader').hide();
                            // optional redirect
                            // window.location.href = response.redirectUrl;
                        }
                        else {
                            // SP StatusText / validation error
                            $.notify(response.message, "error");
                            $('#ajaxLoader').hide();
                        }
                    },
                    error: function () {
                        $.notify("Unexpected server error", "error");
                    }
                });
            });

        });

