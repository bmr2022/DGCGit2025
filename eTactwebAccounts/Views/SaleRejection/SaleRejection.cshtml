        function calculateRow(el) {

            let row = $(el).closest("tr");

            let qty = parseFloat(row.find(".qty").val()) || 0;
            let rate = parseFloat(row.find(".RejRate").val()) ||
                parseFloat(row.find(".rate").val()) || 0;
            let disc = parseFloat(row.find(".disc").val()) || 0;

            let amount = qty * rate;
            amount -= amount * disc / 100;

            row.find(".amount").val(amount.toFixed(2));

            let ig = parseFloat(row.find(".igstp").val()) || 0;
            let cg = parseFloat(row.find(".cgstp").val()) || 0;
            let sg = parseFloat(row.find(".sgstp").val()) || 0;

            row.find(".igsta").val((amount * ig / 100).toFixed(2));
            row.find(".cgsta").val((amount * cg / 100).toFixed(2));
            row.find(".sgsta").val((amount * sg / 100).toFixed(2));
        }
