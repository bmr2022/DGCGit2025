        function isItemAlreadyAdded(itemCode, currentRow) {

            let exists = false;

            $("#ItemDetailTable tbody tr").each(function () {

                let row = $(this);

                if (row[0] !== currentRow[0]) {

                    let code = row.find(".ItemCode-input").val();

                    if (code && code == itemCode) {
                        exists = true;
                        return false;
                    }
                }
            });

            return exists;
        }


