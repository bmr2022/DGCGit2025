    <script>

        function LoadData() {

            var saleBillNo = $('#CustInvoiceNo').val();
            var AccountCode = $('#AccountCode').val();
          
            if (!saleBillNo) {
                alert("Please enter Sale Bill No");
                return;
            }

            $.ajax({
                url: '/SaleRejection/LoadSaleBillData',
                type: 'POST',
                data: { saleBillNo: saleBillNo, AccountCode: AccountCode },
                success: function (response) {

                    // $('#SaleRejectionBody').html(response);
                    $('#SaleRejectionBody').html(response);
                    calculateTotals();


                },
                error: function () {
                    alert("Error loading data");
                }
            });
        }
                function UploadExcel() {

            var fileInput = $('#ExcelFile');
            var file = fileInput.prop("files")[0];

            if (!file) {
                AddErrorCls('ExcelFile');
                $.notify("Please select an Excel file.", "error");
                return;
            } else {
                RemoveErrorCls('ExcelFile');
            }
            var stateCode = $('#StateCode').val();          // Party State
 var companyStateCode = $('#CompanyStateCode').val();  // Company State

            var formData = new FormData();
            formData.append("excelFile", file);
            formData.append("stateCode", stateCode);
            formData.append("companyStateCode", companyStateCode);

             



            // Optional: send extra fields if needed
            // formData.append("Flag", $('#Flag').val());
            

            $.ajax({
                url: "@Url.Action("UploadExcel")",
                type: "POST",
                data: formData,
                processData: false,
                contentType: false,

                success: function (result) {
                    console.log(result.html);

                    // ===== SHOW ERRORS IN DIV =====
                    if (result.errorList && result.errorList.length > 0) {
                        $("#excelErrorList").empty();
                        result.errorList.forEach(function (msg) {
                            $("#excelErrorList").append("<li>" + msg + "</li>");
                        });
                        $("#excelErrorBox").show();
                    } else {
                        $("#excelErrorBox").hide();
                    }

                    // ===== LOAD PARTIAL VIEW =====
                    if (result.html) {
                        $('#SaleRejectionBody').empty();
                        $('#SaleRejectionBody').html(result.html);
                    }

                    calculateTotals();
                    
                },

                error: function (xhr) {
                    if (xhr.status === 400) {
                        // Show controller BadRequest message in error div
                        $("#excelErrorList").empty().append("<li>" + xhr.responseText + "</li>");
                        $("#excelErrorBox").show();
                    } else {
                        $.notify("Unexpected error occurred while uploading Excel.", "error");
                    }
                }
            });
        }


