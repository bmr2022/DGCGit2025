        function calculateRow(el) {

            let row = $(el).closest("tr");

            let qty = parseFloat(row.find(".qty").val()) || 0;
            let rate = parseFloat(row.find(".RejRate").val()) ||
                parseFloat(row.find(".rate").val()) || 0;
            let discPer = parseFloat(row.find(".discPer").val()) || 0;

           
            let basicAmount = qty * rate;

            // Step 2: Discount Amount
            let discAmount = basicAmount * discPer / 100;

            // Set Discount Amount field
            row.find(".discamt").val(discAmount.toFixed(2));

            // Step 3: Net Amount after discount
            let amount = basicAmount - discAmount;

            row.find(".amount").val(amount.toFixed(2));

           

            let ig = parseFloat(row.find(".igstp").val()) || 0;
            let cg = parseFloat(row.find(".cgstp").val()) || 0;
            let sg = parseFloat(row.find(".sgstp").val()) || 0;

            if ($('#AccountCode').val() != 0) {
                row.find(".igsta").val((amount * ig / 100).toFixed(2));
                row.find(".cgsta").val((amount * cg / 100).toFixed(2));
                row.find(".sgsta").val((amount * sg / 100).toFixed(2));
            }
            else {
                row.find(".igsta").val("0.00");
                row.find(".cgsta").val("0.00");
                row.find(".sgsta").val("0.00");
            }

            calculateTotals();
        }

        function calculateTotals() {

            let basicTotal = 0;
            let totalGST = 0;
            let totalQty = 0;
            let itemCount = 0;

            $("#ItemDetailTable tbody tr").each(function () {

                let amt = parseFloat($(this).find(".amount").val()) || 0;
                let ig = parseFloat($(this).find(".igsta").val()) || 0;
                let cg = parseFloat($(this).find(".cgsta").val()) || 0;
                let sg = parseFloat($(this).find(".sgsta").val()) || 0;
                let qty = parseFloat($(this).find(".qty").val()) || 0;
                let itemCode = $(this).find(".ItemCode-input").val();


                basicTotal += amt;
                totalGST += ig + cg + sg;

                totalQty += qty;

                if (itemCode && itemCode.trim() !== "") {
                    itemCount++;
                }
            });

            let netTotal = basicTotal + totalGST;

            $(".lblItemNetAmount").text(basicTotal.toFixed(2));
            $("#ItemNetAmount").val(basicTotal.toFixed(2));
            $("#NetTotal").val(netTotal.toFixed(2));
            calculateroundoffnettotal();
            $(".TotalQty").text(totalQty);
            $(".lblItemCount").text(itemCount);
        }
        function deleteRow(btn) {
            let row = btn.parentNode.parentNode;
            row.remove();
            reindexRows();
            calculateTotals();
        }

        function reindexRows() {

            $("#ItemDetailTable tbody tr").each(function (i) {

                $(this).find("input").each(function () {

                    let name = $(this).attr("name");
                    if (name) {
                        let newName = name.replace(/\[\d+\]/, "[" + i + "]");
                        $(this).attr("name", newName);
                    }
                });

                $(this).find("td:first").contents().first()[0].textContent = i + 1;
            });
        }

        


       


