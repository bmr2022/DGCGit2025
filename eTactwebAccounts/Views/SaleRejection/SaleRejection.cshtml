        function BasicTotal() {

            let amountSum = 0;
            let qtySum = 0;
            let itemCount = 0;

            // Count how many Amount-* elements exist
            const totalItems = $('[id^="Amount-"]').length;

            for (let i = 1; i <= totalItems; i++) {

                let $amountEl = $('#Amount-' + i);
                let $qtyEl = $('#rejQty-' + i);

                if ($amountEl.length === 0 || $qtyEl.length === 0) continue;

                // read value safely (text OR input)
                let amountVal = $amountEl.is('input') ? $amountEl.val() : $amountEl.text();
                let qtyVal = $qtyEl.is('input') ? $qtyEl.val() : $qtyEl.text();

                let amount = parseFloat(amountVal);
                let qty = parseFloat(qtyVal);

                if (isNaN(amount) || isNaN(qty)) continue;

                amountSum += amount;
                qtySum += qty;
                itemCount++;
            }

            $('.lblItemNetAmount').text(amountSum.toFixed(2));
            $('#ItemNetAmount').val(amountSum.toFixed(2));
            $('.TotalQty').text(qtySum.toFixed(2));
            $('.lblItemCount').text(itemCount);
        }

