        function FillSOItemRate(row) {

            var sono = $("#SONO").val() == '0' ? '' : $("#SONO").val();
            var itemCode = $(row).find('.ItemCode-input').val();   // get item from row

            $.ajax({
                type: "POST",
                url: "@Url.Action("FillSOItemRate","SaleInvoice")",
                data: {
                    "sono": sono,
                    "soYearCode": $('#SOYearCode').val(),
                    "accountCode": $('#AccountCode').val(),
                    "custOrderNo": $('#CustOrderNo').val(),
                    "itemCode": itemCode,
                    "SubInvoicetype": $('#SubInvoicetype').val()
                },
                dataType: "json",
                success: function (result) {

                    if (result != null) {

                        var obj = $.parseJSON(result);

                        if (obj.StatusCode == 200 && obj.Result.length > 0) {

                            var data = obj.Result[0];

                            var rate = data.Rate == '' ? 0 : parseFloat(data.Rate);
                            var igst = data.IGST == '' ? 0 : parseFloat(data.IGST);

                            var stateCode = $('#StateCode').val();          // Party State
                            var companyStateCode = $('#CompanyStateCode').val();  // Company State




                            // ✅ Fill Grid Fields
                            $(row).find('.rate').val(rate.toFixed(2));
                            $(row).find('.RejRate').val(rate.toFixed(2));
                            $(row).find('.Unit').val(data.unit);
                            $(row).find('.HSNNo').val(data.HsnNo);
                            $(row).find('.GroupName').val(data.Group_name);
                            $(row).find('.ItemLocation').val(data.Location);
                            // $(row).find('.igstp').val(data.IGST);

                            if ($('#GSTNO').val()!='')
                            {
                            // ✅ GST Logic
                            if (stateCode === companyStateCode ) {
                                // Same state → CGST + SGST (half-half)
                                var halfGST = igst / 2;

                                $(row).find('.cgstp').val(halfGST.toFixed(2));
                                $(row).find('.sgstp').val(halfGST.toFixed(2));
                                $(row).find('.igstp').val(0);

                            } else {
                                // Different state → IGST only
                                $(row).find('.igstp').val(igst.toFixed(2));
                                $(row).find('.cgstp').val(0);
                                $(row).find('.sgstp').val(0);
                            }
                            }
                            else
                            {
                                // If GST number not available → Set all taxes to 0
                                $(row).find('.igstp').val(0);
                                $(row).find('.cgstp').val(0);
                                $(row).find('.sgstp').val(0);
                            }
                            validateQtyByUnit($(row).find('.Unit').val(),'qty');
                          
                        }
                    }
                },
                complete: function () {
                    calculateRow(row); // Trigger calculation after rate is set
                },

                error: function (xhr) {
                    console.log("Error: " + xhr.responseText);
                }
            });
        }


        function recalculateGSTForAllRows() {

            var stateCode = $('#StateCode').val();
            var companyStateCode = $('#CompanyStateCode').val();

            $("#ItemDetailTable tbody tr").each(function () {

                let row = $(this);

                let igst = parseFloat(row.find(".igstp").val()) ||
                    parseFloat(row.find(".cgstp").val()) * 2 || 0;

                if (stateCode === companyStateCode && stateCode != 0) {

                    // Same state → CGST + SGST
                    let halfGST = igst / 2;

                    row.find('.cgstp').val(halfGST.toFixed(2));
                    row.find('.sgstp').val(halfGST.toFixed(2));
                    row.find('.igstp').val(0);

                }
                else if (stateCode != companyStateCode && stateCode != 0) {

                    // Different state → IGST
                    row.find('.igstp').val(igst.toFixed(2));
                    row.find('.cgstp').val(0);
                    row.find('.sgstp').val(0);
                }
                else {

                    // State not available
                    row.find('.igstp').val(0);
                    row.find('.cgstp').val(0);
                    row.find('.sgstp').val(0);
                }

                calculateRow(row); // Recalculate row
            });

            calculateTotals();
        }
            
        
