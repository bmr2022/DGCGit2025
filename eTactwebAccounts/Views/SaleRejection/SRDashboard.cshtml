                $.notify(deleteMessage, "error");
            }
            GetFormRights();
            var FromDate = $('#FinFromDate').val().split(" ")[0];
            $("#FinFromDate").datepicker({ dateFormat: 'dd/mm/yy' }).datepicker("setDate", FromDate);
            $('#FinToDate').datepicker({ dateFormat: 'dd/mm/yy' }).datepicker("setDate", 'now');

            $('#PartCode').rules('remove', 'required');
            FillCustomerName();
            FillDocument();
            FillItemName();
            FillPartCode();
            FillAgainstSaleBillNo();
            FillVoucherNo();
            FillInvoiceNo();
            FillGateNo();
            FillMRNNo();
            GetSearchData();
            GetTotalAmounts();
            $('#CustInvoiceNo').select2();
            $('#Account_Name').select2();
            $('#MrnNo').select2();
            $('#GateNo').select2();
            $('#PartCode').select2();
            $('#ItemName').select2();
            $('#AgainstBillNo').select2();
            $('#VoucherNo').select2();
            $('#CustInvoiceNo').val($('#hiddenCustInvoiceNo').val());
            $('#MrnNo').val($('#hiddenMrnNo').val());
            $('#GateNo').val($('#hiddenGateNo').val());
            $('#PartCode').val($('#hiddenPartCode').val());
            $('#ItemName').val($('#hiddenItemName').val());
            $('#AgainstBillNo').val($('#hiddenAgainstBillNo').val());
            // $('#DocumentName').val($('#hiddenDocumentName').val());
            $('#VoucherNo').val($('#hiddenVoucherNo').val());
            $('#Account_Name').val($('#hiddenAccountName').val());

        });
        function GetFormRights() {

            $.ajax({
                url: "@Url.Action("GetFormRights")",
                type: "POST",
                async: false,
                success: function (data) {

                    if (data != null) {
                        var obj = $.parseJSON(data);
                        if (obj.Result.Table.length == 0) {
                            var rowCounter = $('#divDashboardGrid tr').length;
                            for (var i = 0; i < rowCounter; i++) {
                                $('#viewCursorDiv-' + i).empty();
                                $('#viewCursorDiv-' + i).append(`<a class="table-link link-success noCursor" id="viewNoCursor"">
                                                                                                                                <span class="fa-stack">
                                                                                                                                    <i class="fa fa-square fa-stack-2x"></i>
                                                                                                                                    <i class="fa-solid fa-magnifying-glass fa-stack-1x fa-inverse"></i>
                                                                                                                                </span>
                                                                                                                            </a>`);
                            }
                            for (var i = 0; i < rowCounter; i++) {
                                $('#editCursorDiv-' + i).empty();
                                $('#editCursorDiv-' + i).append(`<a class="table-link link-primary noCursor">
                                                                                                                                        <span class="fa-stack">
                                                                                                                                            <i class="fa fa-square fa-stack-2x"></i>
                                                                                                                                            <i class="fa fa-pencil fa-stack-1x fa-inverse"></i>
                                                                                                                                        </span>
                                                                                                                                    </a>`);
                            }
                            for (var i = 0; i < rowCounter; i++) {
                                $('#deleteCursorDiv-' + i).empty();
                                $('#deleteCursorDiv-' + i).append(`<a class="table-link link-danger noCursor">
                                                                                                                                        <span class="fa-stack">
                                                                                                                                            <i class="fa fa-square fa-stack-2x"></i>
                                                                                                                                            <i class="fa-solid fa-trash fa-stack-1x fa-inverse"></i>
                                                                                                                                        </span>
                                                                                                                                    </a>`);
                            }
                            $("#divDashboardGrid").css("display", "none");
                            $(".totalrows").css("display", "none");
                            $("#SParam").hide();
                        } else {

                            var optAll = obj.Result.Table[0].OptAll;
                            var optSave = obj.Result.Table[0].OptSave;
                            var optUpdate = obj.Result.Table[0].OptUpdate;
                            var optDelete = obj.Result.Table[0].OptDelete;
                            var optView = obj.Result.Table[0].OptView;
                            var rowCounter = $('#divDashboardGrid tr').length;
                            if (!optAll) {
                                if (!optSave) {

                                    $("#savebtn").css("pointer-events", "none");
                                } else {
                                    $("#savebtn").css("pointer-events", "");
                                }
                                if (!optView) {

                                    for (var i = 0; i < rowCounter; i++) {
                                        $('#viewCursorDiv-' + i).empty();
                                        $('#viewCursorDiv-' + i).append(`<a class="table-link link-success noCursor" id="viewNoCursor"">
                                                                                                <span class="fa-stack">
                                                                                                    <i class="fa fa-square fa-stack-2x"></i>
                                                                                                    <i class="fa-solid fa-magnifying-glass fa-stack-1x fa-inverse"></i>
                                                                                                </span>
                                                                                            </a>`);
                                    }
                                }
                                if (!optUpdate) {
                                    for (var i = 0; i < rowCounter; i++) {
                                        $('#editCursorDiv-' + i).empty();
                                        $('#editCursorDiv-' + i).append(`<a class="table-link link-primary noCursor">
                                                                                                <span class="fa-stack">
                                                                                                    <i class="fa fa-square fa-stack-2x"></i>
                                                                                                    <i class="fa fa-pencil fa-stack-1x fa-inverse"></i>
                                                                                                </span>
                                                                                            </a>`);
                                    }
                                }
                                if (!optDelete) {
                                    for (var i = 0; i < rowCounter; i++) {
                                        $('#deleteCursorDiv-' + i).empty();
                                        $('#deleteCursorDiv-' + i).append(`<a class="table-link link-danger noCursor">
                                                                                                <span class="fa-stack">
                                                                                                    <i class="fa fa-square fa-stack-2x"></i>
                                                                                                    <i class="fa-solid fa-trash fa-stack-1x fa-inverse"></i>
                                                                                                </span>
                                                                                            </a>`);
                                    }
                                }
                                if (!(optUpdate || optDelete || optView)) {
                                    $("#divDashboardGrid").css("display", "none");
                                    $(".totalrows").css("display", "none");
                                    $("#SParam").hide();
                                }
                            }
                        }
                    }
                },
                error: function (errMsg) {
                    $.notify(errMsg, { position: "top center", className: "error" });
                }
            });
        }
        var currentSearchColumn = null;
        $("#search-box").on("keyup", function () {
            var value = $(this).val().toLowerCase();
            $("#divSRDashboardGrid tr").filter(function () {
                if (currentSearchColumn !== null) {
                    var columnText = $(this).find('td').eq(currentSearchColumn).text().toLowerCase();
                    $(this).toggle(columnText.indexOf(value) > -1);
                } else {
                    $(this).toggle($(this).text().toLowerCase().indexOf(value) > -1);
                }
            });
        });
        $(document).on("click", "th[data-columnno]", function () {
            currentSearchColumn = $(this).data('columnno');
            $("#search-box").val('').trigger('keyup');
        });
        $(document).on("click", ".sortCol", function () {
            var $column = $(this).parent().closest("th");
            var colno = $(this).data('columnno');
            var currentOrder = $(this).data('sortorder');

            $('.sortCol').css('color', 'white');

            if (currentOrder === 'asc') {
                sortTable('SRDashboardGrid', colno, false);
                $(this).data('sortorder', 'desc');
                $(this).css('color', 'yellow');
                //$(this).css('font-size', 'larger');
                $(this).find('i:first').removeClass('fa-arrow-up');
                $(this).find('i:first').addClass('fa-arrow-down');
            } else {
                sortTable('SRDashboardGrid', colno, true);
                $(this).data('sortorder', 'asc');
                $(this).css('color', 'yellow');
                // $(this).css('font-size', 'larger');
                $(this).find('i:first').removeClass('fa-arrow-down');
                $(this).find('i:first').addClass('fa-arrow-up');
            }
        });
        function confirmDelete(event) {

            event.preventDefault();
            if (confirm("Are you sure you want to delete this entry?")) {
                var linkUrl = $(event.currentTarget).attr("href");
                linkUrl = linkUrl + "&fromDate=" + $('#FinFromDate').val() + "&toDate=" + $('#FinToDate').val() + "&custInvoiceNo=" + $('#CustInvoiceNo').val() + "&accountName=" + $('#Account_Name').val() + "&mrnNo=" + $('#MrnNo').val() + "&gateNo=" + $('#GateNo').val()
                    + "&partCode=" + $('#PartCode').val() + "&itemName=" + $('#ItemName').val() + "&againstBillNo=" + $('#AgainstBillNo').val() + "&voucherNo=" + $('#VoucherNo').val();
                window.location.href = linkUrl;
            }
        }
        $("#btnGridExcel").click(function () {
            const table = document.querySelector("#SRDashboardGrid");
            const rows = table.querySelectorAll("tr");
            const data = [];

            const headerRow = rows[0];
            const headerData = [];

            headerRow.querySelectorAll("th").forEach((cell) => {
                // cell.style.backgroundColor = "#fcba03";
                headerData.push(cell.textContent);
            });

            data.push(headerData);

            for (let i = 1; i < rows.length; i++) {
                const rowData = [];
                rows[i].querySelectorAll("td").forEach((cell) => {
                    rowData.push(cell.textContent);
                });
                data.push(rowData);
            }

            const ws = XLSX.utils.aoa_to_sheet(data);

            ws["!cols"] = [{ wch: 15 }, { wch: 15 }, { wch: 15 }, /* ... */];

            const wb = XLSX.utils.book_new();
            XLSX.utils.book_append_sheet(wb, ws, "Sheet 1");


            XLSX.writeFile(wb, "SRDashboardData.xlsx");
        });
        function FillCustomerName() {

            var fromDate = $('#FinFromDate').val();
            var toDate = $('#FinToDate').val();
            $.ajax({
                type: "POST",
                data: { "fromDate": fromDate, "toDate": toDate },
                url: "@Url.Action("FillCustomerName")",
                dataType: "json",
                async: false,
                success: function (result, status, error) {

                    if (result != null) {

                        var obj = $.parseJSON(result);
                        if (obj.Result != null) {
                            $('#Account_Name').empty();
                            $('#Account_Name').append('<option value="">-Select-</option>');
                            if (obj.StatusCode != 500) {
                                $.each(obj.Result.Table, function (index, val) {
                                    $('#Account_Name').append("<option value=" + val.AccountCode + ">" + val.CustomerName + "</option>");
                                });
                            }
                        }
                    }
                }
            });
        }
        function GetTotalAmounts() {

            let dataObj = {
                fromDate: $('#FinFromDate').val(),
                toDate: $('#FinToDate').val(),
                CustInvoiceNo: $('#CustInvoiceNo').find(':selected').text() === "-Select-" ? "" : $('#CustInvoiceNo').find(':selected').text(),
                AccountCode: $('#Account_Name').val(),
                MrnNo: $('#MrnNo').find(':selected').text() === "-Select-" ? "" : $('#MrnNo').find(':selected').text(),
                GateNo: $('#GateNo').find(':selected').text() === "-Select-" ? "" : $('#GateNo').find(':selected').text(),
                ItemCode: $('#ItemName').val(),
                AgainstBillNo: $('#AgainstBillNo').find(':selected').text() === "-Select-" ? "" : $('#AgainstBillNo').find(':selected').text(),
                VoucherNo: $('#VoucherNo').find(':selected').text() === "-Select-" ? "" : $('#VoucherNo').find(':selected').text(),

            };

            $.ajax({
                url: '/SaleRejection/GetTotalAmount',
                type: 'GET',
                data: dataObj,
                dataType: 'json',

                success: function (data) {

                    const obj = typeof data === "string" ? JSON.parse(data) : data;

                    // Clear only dynamic footer cells
                    $('#SRDashboardGrid tfoot td[id^="tfoot_"]').text('');
                    // enableTableSorting('#SRDashboardGrid');
                    if (!obj?.Result?.length) return;

                    let row = obj.Result[0];

                    // 🔥 KEY MAPPING (API → Footer)
                    const keyMap = {
                        BasicAmount: 'BillAmt',
                        NetAmount: 'InvNetAmt',
                        TaxableAmount: 'Taxableamt'
                    };

                    Object.keys(row).forEach(function (key) {

                        if (!keyMap[key]) return;

                        let value = parseFloat(row[key]);
                        if (isNaN(value)) return;

                        let footerCell = $('#tfoot_' + keyMap[key]);
                        if (footerCell.length) {
                            footerCell.text(value.toFixed(2));
                        }
                    });
                },

                error: function (err) {
                    console.error("❌ Error fetching totals:", err);
                }
            });
        }
