        $(document).on("click", ".sortCol", function () {

            var $th = $(this); // this IS th.sortCol
            var colno = parseInt($th.attr('data-columnno'), 10);
            var currentOrder = $th.attr('data-sortorder') || 'asc';

            // Reset all headers
            $('.sortCol')
                .attr('data-sortorder', 'asc')
                .find('i')
                .removeClass('fa-arrow-up fa-arrow-down');

            if (currentOrder === 'asc') {
                sortTable(colno, true);   // ASC
                $th.attr('data-sortorder', 'desc');
                $th.find('i:first').addClass('fa-arrow-up');
            } else {
                sortTable(colno, false);  // DESC
                $th.attr('data-sortorder', 'asc');
                $th.find('i:first').addClass('fa-arrow-down');
            }
        });


        function sortTable(columnIndex, ascending) {

            var table = $('#SRDashboardGrid');
            var rows = table.find('#divSRDashboardGrid > tr').toArray();

            rows.sort(function (a, b) {
                var aValue = $(a).find('td').eq(columnIndex).text();
                var bValue = $(b).find('td').eq(columnIndex).text();

                var aIntValue = 0;
                var bIntValue = 0;
                if (/^\d*\.?\d+$/.test(aValue) && /^\d*\.?\d+$/.test(bValue)) {
                    aIntValue = parseInt(aValue, 10);
                    bIntValue = parseInt(bValue, 10);
                }

                if (aIntValue > 0) {
                    if (ascending) {
                        return aValue - bValue;
                    } else {
                        return bValue - aValue;
                    }
                } else {
                    if (ascending) {
                        return aValue.localeCompare(bValue);
                    } else {
                        return bValue.localeCompare(aValue);
                    }
                }
            });

            $.each(rows, function (index, row) {
                table.children('#divSRDashboardGrid').append(row);
            });
        }




