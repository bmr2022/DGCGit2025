@model eTactWeb.DOM.Models.SaleRejectionDashboard

@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Views/Shared/_LayoutMain.cshtml";
}
<div class="shadow-lg">
    <div class="card rounded border-light bg-gradient">
        <div class="card-header card-headerBG text-light bg-gradient">
            <h5>
                Sale Rejection - <strong>Dashboard</strong>
                <span class="d-flex float-end" style="margin-top:-2px;">
                    <a asp-action="Index" asp-controller="SaleRejection" class="btn btn-sm btn-outline-light bg-gradient" id="savebtn">
                        <i class="fa fa-plus-circle fafw fa-lg" aria-hidden="true"></i>
                        Add New
                    </a>
                </span>
            </h5>
        </div>
        <div class="card-body">
            <div class="card overflow-auto">
                <div class="card-body">
                    <form id="SParam">
                        <div class="row">
                            <div class="col-sm-3 col-md-6 col-lg-2 col-xl-2">
                                <div class="row">
                                    <div class="col">
                                        <label class="form-label">From Date</label>
                                        <input asp-for="FinFromDate" maxlength="10" class="form-control" />
                                    </div>
                                    <div class="col">
                                        <label class="form-label">To Date</label>
                                        <input asp-for="FinToDate" maxlength="10" class="form-control" />
                                    </div>
                                </div>
                            </div>
                            <div class="col-sm-3 col-md-6 col-lg-4 col-xl-1">
                                <label asp-for="SummaryDetail" class="form-label">Summary/Detail</label>
                                <select class="form-select" asp-for="SummaryDetail" onchange="GetSearchData();">
                                    <option>-Select-</option>
                                    <option value="Summary" selected>Summary</option>
                                    <option value="Detail">Detail</option>
                                </select>
                            </div>
                            <div class="col-sm-3 col-md-6 col-lg-4 col-xl-1">
                                <label asp-for="CustInvoiceNo" class="form-label">Cust Invoice No</label>
                                <select asp-for="CustInvoiceNo" class="form-control">
                                    <option value="">-Select-</option>
                                </select>
                                <input type="hidden" value="@Model.CustInvoiceNo" id="hiddenCustInvoiceNo" />
                            </div>
                            <div class="col-sm-3 col-md-6 col-lg-4 col-xl-2">
                                <label asp-for="Account_Name" class="form-label">Account Name</label>
                                <select asp-for="Account_Name" class="form-control">
                                    <option value="">-Select-</option>
                                </select>
                                <input type="hidden" value="@Model.Account_Name" id="hiddenAccountName" />

                            </div>
                            <div class="col-sm-3 col-md-6 col-lg-4 col-xl-2">
                                <label asp-for="MrnNo" class="form-label">Mrn no</label>
                                <select asp-for="MrnNo" class="form-control">
                                    <option value="">-Select-</option>
                                </select>
                                <input type="hidden" value="@Model.MrnNo" id="hiddenMrnNo" />
                            </div>
                            <div class="col-sm-3 col-md-6 col-lg-4 col-xl-2">
                                <label asp-for="GateNo" class="form-label">Gate No</label>
                                <select asp-for="GateNo" class="form-control">
                                    <option value="">-Select-</option>
                                </select>
                                <input type="hidden" value="@Model.GateNo" id="hiddenGateNo" />
                            </div>
                            <div class="col-sm-3 col-md-6 col-lg-4 col-xl-2">
                                <label asp-for="PartCode" class="form-label">PartCode</label>
                                <select asp-for="PartCode" class="form-control">
                                    <option value="">-Select-</option>
                                </select>
                                <input type="hidden" value="@Model.PartCode" id="hiddenPartCode" />
                            </div>
                            <div class="col-sm-3 col-md-6 col-lg-4 col-xl-2">
                                <label asp-for="ItemName" class="form-label">Item Name</label>
                                <select asp-for="ItemName" class="form-control">
                                    <option value="">-Select-</option>
                                </select>
                                <input type="hidden" value="@Model.ItemName" id="hiddenItemName" />
                            </div>
                            <div class="col-sm-3 col-md-6 col-lg-4 col-xl-2">
                                <label asp-for="AgainstBillNo" class="form-label">Against Bill No</label>
                                <select asp-for="AgainstBillNo" class="form-control">
                                    <option value="">-Select-</option>
                                </select>
                                <input type="hidden" value="@Model.AgainstBillNo" id="hiddenAgainstBillNo" />
                            </div>
                            <div class="col-sm-3 col-md-6 col-lg-4 col-xl-2">
                                <label asp-for="VoucherNo" class="form-label">Voucher No</label>
                                <select asp-for="VoucherNo" class="form-control">
                                    <option value="">-Select-</option>
                                </select>
                                <input type="hidden" value="@Model.VoucherNo" id="hiddenVoucherNo" />
                            </div>
                            <div class="col-sm-6 col-md-6 col-lg-6 col-xl-6 d-flex justify-content-end mt-3">
                                <button class="btn btn-sm btn-outline-info" type="button" onclick="GetSearchData();">
                                    <i class="fa-solid fa-magnifying-glass fa-fw fa-lg "></i>SEARCH
                                </button>
                                <button class="btn btn-sm btn-outline-success me-3" style="padding:3px;height:30px;width:100px;margin-left:20px;" type="button" id="btnGridExcel">
                                    <i class="fa-solid fa-upload fa-fw fa-lg "></i>EXCEL
                                </button>
                                <a class="btn btn-sm btn-outline-danger" asp-controller="SaleRejection" asp-action="SRDashboard">
                                    <i class="fa-solid fa-rotate fa-fw fa-lg"></i>RESET
                                </a>
                                <div class="ms-auto d-flex align-items-center">
                                    <div class="col-md-4">
                                        <label class="form-label me-2">Global search</label>
                                    </div>
                                    <div class="col-md-8">
                                        <input type="text" class="form-control" id="search-box" placeholder="Search..." style="background-color:#FFFACD;">
                                    </div>
                                </div>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
        <div class="card-body pb-0 pt-0">
            <div class="progress" style="height: 4px;">
                <div class="progress-bar progress-bar-striped bg-info" role="progressbar" style="width: 100%" aria-valuenow="100" aria-valuemin="0" aria-valuemax="100"></div>
            </div>
        </div>
        <div class="card-body">
            <div class="card overflow-auto">
                <div class="card-body" id="divDashboardGrid">
                    <partial name="_SRDashboardGrid" />
                </div>
            </div>
        </div>
    </div>
</div>
@section Scripts
