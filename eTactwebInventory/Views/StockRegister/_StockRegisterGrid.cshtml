@model eTactWeb.DOM.Models.StockRegisterModel
@using eTactWeb.Data.Common
@inject EncryptDecrypt encryptDecrypt

<style>
    #container {
        display: flex;
    }

        #container > div {
            flex: 1;
        }

    .table-container {
        max-height: 350px; /* 👈 set max height here */
        overflow-y: auto;
    }

   
   


    table tfoot {
        position: sticky;
        bottom: 0;
        background: linear-gradient(180deg, #b3e0f5, #80d4f0) !important;
        color: #222;
        z-index: 1;
        box-shadow: 0 -2px 5px rgba(0,0,0,0.1);
        height: 30px;
    }

        table tfoot td {
            font-weight: bold;
            border-top: 2px solid #dee2e6;
            font-size: 13px;
            color: #222;
        }

    #container {
        display: flex;
    }

        #container > div {
            flex: 1;
            margin-right: 10px;
        }

    #SRDashboardGrid {
        width: 100%;
        border-collapse: collapse;
    }

    #SOThead th {
        background-color: #127387;
        position: sticky;
        top: -2px;
        z-index: 1;
    }

    .sort-icon {
        padding: 5px;
        margin: 5px;
        vertical-align: top;
    }

    .ascCol {
        font-size: 15px;
        vertical-align: bottom;
    }

    .descCol {
        font-size: 15px;
        vertical-align: super;
    }

    #SRDashboardGrid tbody td {
        font-weight: normal !important;
    }
     .stock-warning {
    background-color: #ffcccc !important; /* light red */
    color: #000;
}
</style>

<div class="table-responsive" style="max-height:350px;">
    <table class="table table-hover table-bordered table-striped TbCss text-nowrap mb-0"
           id="SRDashboardGrid">

        <thead class="bg-gradient card-headerBG text-light" id="SOThead">
            <tr>
                <th>Sr#</th>
          
                @if (Model.Headers != null && Model.Headers.Any())
                {
                    var colIndex = 1;
                    foreach (var col in Model.Headers)
                    {
                        <th data-columnno="@colIndex" data-sortorder="asc" class="sortCol">
                            <span style="padding:5px;margin:5px" class="sort-icon"><i class="fa" aria-hidden="true"></i></span>
                            @col.Title
                        </th>
                        colIndex++;
                    }
                }
            </tr>
        </thead>

        <tbody id="divSRDashboardGrid">
            @if (Model.Rows == null || Model.Rows.Count == 0)
            {
                <tr class="text-center">
                    <td colspan="@((Model.Headers?.Count ?? 0) + 2)" class="text-black-50">
                        <strong>NO DATA FOUND</strong>
                    </td>
                </tr>
            }
            else
            {
                int Cntr = 0;

                foreach (var row in Model.Rows)
                {
                    Cntr++;
                    bool highlightRow = false;

                    if (Model.ReportType == "STOCKSUMMARY")
                    {
                        if (row.ContainsKey("TotalStock") && row["TotalStock"] != null)
                        {
                            decimal totalStockValue = 0;

                            if (decimal.TryParse(row["TotalStock"].ToString(), out totalStockValue))
                            {
                                if (totalStockValue <= 0)
                                {
                                    highlightRow = true;
                                }
                            }
                        }
                    }
                    <tr class="@(highlightRow ? "stock-warning" : "")">
                        <th>@Cntr</th>


                        @if (Model.Headers != null && Model.Headers.Any())
                        {
                            foreach (var col in Model.Headers)
                            {
                                <td class="grid-cell" data-field="@col.Field">
                                    @{
                                        if (row.ContainsKey(col.Field) && row[col.Field] != null)
                                        {
                                            var value = row[col.Field];

                                            if (value is decimal || value is double || value is float)
                                            {
                                                <span class="num">@string.Format("{0:0.00}", value)</span>
                                            }
                                            else
                                            {
                                                @value
                                            }
                                        }
                                    }
                                </td>

                            }
                        }
                    </tr>
                }
            }
        </tbody>

        <tfoot class="bg-light fw-bold">
            <tr>
                <!-- Sr# column -->
                <td></td>

                @if (Model.Headers != null && Model.Headers.Any())
                {
                    bool isFirst = true;
                    foreach (var col in Model.Headers)
                    {
                        if (isFirst)
                        {
                            <td>Total</td>
                            isFirst = false;
                        }
                        else
                        {
                            <td id="tfoot_@col.Field"></td>
                        }
                    }
                }
            </tr>
        </tfoot>

    </table>
</div>
@{
    int totalPages = (int)Math.Ceiling((double)Model.TotalRecords / Model.PageSize);
    int displayedRows = Model.PageNumber * Model.PageSize;
    if (displayedRows > Model.TotalRecords)
    {
        displayedRows = Model.TotalRecords;
    }
}

<center>
    <strong>
        <span style="margin-right: 30px;">TOTAL ROWS  : <span>@displayedRows</span></span>
        <span>TOTAL RECORDS : <span>@Model.TotalRecords</span></span>
    </strong>
</center>



@if (Model.TotalRecords > 0)
{
    //int totalPages = (int)Math.Ceiling((double)Model.TotalRecords / Model.PageSize);

    <ul class="pagination d-flex align-items-center">

        @if (Model.PageNumber > 1)
        {
            <li class="page-item">
                <a class="page-link page-btn" data-page="@(Model.PageNumber - 1)" href="#">Previous</a>
            </li>
        }

        @if (Model.PageNumber > 3)
        {
            <li class="page-item">
                <a class="page-link page-btn" data-page="1" href="#">1</a>
            </li>
            <li class="page-item disabled"><a class="page-link">...</a></li>
        }

        @for (int i = Math.Max(1, Model.PageNumber - 2); i <= Math.Min(Model.PageNumber + 2, totalPages); i++)
        {
            <li class="page-item @(i == Model.PageNumber ? "active" : "")">
                <a class="page-link page-btn" data-page="@i" href="#">@i</a>
            </li>
        }

        @if (Model.PageNumber < totalPages - 2)
        {
            <li class="page-item disabled"><a class="page-link">...</a></li>
            <li class="page-item">
                <a class="page-link page-btn" data-page="@totalPages" href="#">@totalPages</a>
            </li>
        }

        @if (Model.PageNumber < totalPages)
        {
            <li class="page-item">
                <a class="page-link page-btn" data-page="@(Model.PageNumber + 1)" href="#">Next</a>
            </li>
        }

    </ul>
}

